---
import Header from './partials/_Header.astro'
import Footer from './partials/_Footer.astro'

import Skeleton from "./_Skeleton.astro"
---



<Skeleton>

  {/* This line propagates the OpenGraph data to the Skeleton's <head> */}
  <slot name="head" slot="head" />

  <Header />
  <article id="site_content" class="content-grid">
    <slot />
  </article>
  <Footer />

</Skeleton>


<style lang="scss" is:global>

  @use '@styles/variables' as *;
  @use '@styles/utils' as *;


  #site_content {
    container-type: inline-size;
    margin-block: space(md);
    block-size: 100%;

    &, .full-width {
      --_content-max-width: #{$blog-max-width};
      --_breakout-max-width: #{$blog-breakout-width};
    }
  }

</style>
