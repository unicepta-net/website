---
import { Picture } from 'astro:assets'


interface Props {
  src: ImageMetadata
  alt: string
  caption?: string
  layout?: 'breakout' | 'left' | 'right'
  context?: 'default' | 'blog'
}

const { src, alt, caption, layout, context = 'default' } = Astro.props


const maxWidth = context != 'blog' ? 'var(--body-max-width)' : 'var(--blog-max-width)'
---





<figure data-layout={ layout } style=`--context-max-width: ${ maxWidth };`>
  <Picture
    src={ src }
    alt={ alt }
    formats={[ 'avif', 'webp' ]}
    widths={[ 800, 1600, src.width ]}
    sizes=`(max-width: 720px) 800px, (max-width: 1080px) 1600px, ${src.width}px`
  />
  <figcaption>{ caption }</figcaption>
</figure>





<style lang="scss">

  @use '@styles/variables' as *;
  @use '@styles/utils' as *;


  figure {

    figcaption {
      margin-block-start: .5em;
      font-style: italic;
      font-size: font-size(xs);
      text-align: center;
    }


    picture, img {
      width: 100%; height: 100%;
      border-radius: border-radius(sm);
    }


    &[data-layout='breakout'] {
      margin-block: space(md);

      @container (min-width: #{ $blog-max-width + ($image-breakout-size * 2) }) {
        margin-block: space(lg);
        width: calc(var(--context-max-width) + ( var(--image-breakout-size) * 2 ));
        margin-inline-start: calc( var(--image-breakout-size) * -1 );
      }
    }


    @container (min-width: #{ $blog-max-width }) {
      &[data-layout='right'] {
        float: right;
        margin-inline-start: space(lg);
        max-width: 50%;

        figcaption { text-align: right; }
      }

      &[data-layout='left'] {
        float: left;
        margin-inline-end: space(lg);
        max-width: 50%;

        figcaption { text-align: left; }
      }
    }
  }

</style>
