---
import { Picture } from 'astro:assets'


interface Props {
  src: ImageMetadata
  alt: string
  caption?: string
  breakout?: boolean
}

const { src, alt, caption, breakout } = Astro.props
---





<figure class:list={[{
  'breakout': breakout,
}]} >
  <Picture
    src={ src }
    alt={ alt }
    formats={[ 'avif', 'webp' ]}
    widths={[ 800, 1600, src.width ]}
    sizes=`(max-width: 720px) 800px, (max-width: 1080px) 1600px, ${src.width}px`
  />
  <figcaption>{ caption }</figcaption>
</figure>





<style lang="scss">

  @use '@styles/variables' as *;
  @use '@styles/utils' as *;


  figure {
    padding-block-end: 1lh;


    figcaption {
      margin-block-start: .5em;
      font-style: italic;
      font-size: font-size(xs);
      text-align: center;
    }


    picture, img {
      width: 100%; height: 100%;
      border-radius: border-radius(sm);
    }
  }

</style>
