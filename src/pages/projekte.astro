---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';

const projects = (await getCollection('projekte')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
  title="Projekte | unicepta"
  description="Learn about Jeanine White's most recent projects"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Unsere Projekte"
        tagline="Unsere Projektreferenzen zeigen, wie wir komplexe Kommunikationsaufgaben meistern – von der Krisenbewältigung bis zur erfolgreichen Einbindung von Stakeholdern. Sie stehen für unser Engagement, maßgeschneiderte Lösungen zu entwickeln und Vertrauen zu stärken."
        align="start"
      />
      <Grid>
        {
          projects.map((project) => (
            <li>
              <PortfolioPreview project={project} />
            </li>
          ))
        }
      </Grid>
    </main>
    <ContactCTA />
  </div>
</BaseLayout>
