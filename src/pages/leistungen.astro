---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import ServicePreview from '../components/ServicePreview.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';

const services = (await getCollection('leistungen')).sort(
  (a, b) => b.data.weight.valueOf() - a.data.weight.valueOf(),
);
---

<BaseLayout
  title="Leistungen | unicepta"
  description="Learn about Jeanine White's most recent projects"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Unser Leistungsportfolio"
        tagline="Wir gestalten Kommunikation, die wirkt – in der Krise und im Dialog. Als erfahrene Berater:innen, kritische Sparringspartner und verlässliche Begleiter entwickeln wir Kommunikationsstrategien, die Vertrauen schaffen, Orientierung geben und Akzeptanz sichern. Ob Krisenkommunikation, Notfallmanagement oder Beteiligungsverfahren: Wir helfen dabei, komplexe Situationen zu meistern – professionell, strukturiert und mit klarem Fokus auf Wirkung."
        align="start"
      />
      <Grid>
        {
          services.map((service) => (
            <li>
              <ServicePreview service={service} />
            </li>
          ))
        }
      </Grid>
    </main>
    <ContactCTA />
  </div>
</BaseLayout>
